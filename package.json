{
  "name": "online-image-transformation-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 8090",
    "dev:backend": "PORT=8091 tsx watch backend/src/index.ts",
    "build": "npm run build:frontend && npm run build:backend",
    "build:backend": "tsc -p backend/tsconfig.json",
    "build:frontend": "next build",
    "start": "node dist/backend/index.js",
    "typecheck": "tsc --noEmit && tsc -p backend/tsconfig.json --noEmit",
    "preview:prod": "npm run build && NODE_ENV=production npm run start"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "cloudinary": "^2.10.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.468.0",
    "next": "^16.2.9",
    "ogl": "^1.0.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
